{
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "all",
  "semi": true,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "scripts/browser-tools.ts",
    "node_modules/**/*",
    ".pnpm-store/**/*",
    "coverage/**/*",
    ".bun-check/**/*"
  ]
}
